# dicti configuration, copy to ~/.config/dicti/config.toml and edit.
# All keys are optional; anything omitted uses the built-in default shown here.

# --- Whisper backend ---
whisper_url = "http://127.0.0.1:8178/inference"
language = "auto"            # "auto", "en", "pl", ... (whisper language code)
translate = false            # Whisper's translate task: speak ANY language, get ENGLISH text.
                             #   One-directional: the target is always English (model limit;
                             #   English -> Polish etc. would need a separate translation model).
                             #   This is the startup default; toggle live with `dictate-translate`
                             #   (bindable to a key). Translation quality is rougher than plain
                             #   transcription, especially on the quantized medium model.

# --- Dictation mode ---
mode = "streaming"           # "streaming" = text appears phrase-by-phrase as you pause
                             #               (append-only, never rewrites typed text).
                             # "batch"     = transcribe the whole utterance once at STOP.

# Streaming tuning (only used when mode = "streaming"). Each pass re-transcribes the whole
# utterance so far (full context = best quality) and types only the words that have
# stabilised. Append-only: text already typed is never rewritten.
stream_interval_sec = 2.0    # target seconds between transcription passes. Lower = snappier
                             #   but more inference load; higher = calmer, slightly laggier.
max_context_sec = 60.0       # cap the re-transcribed window. Past this the text so far is
                             #   committed and a fresh context window starts, so a very long
                             #   dictation doesn't make each pass slower without bound.

# --- Session limits ---
max_record_sec = 3600        # hard safety cap on a single session (1 hour)
silence_timeout_sec = 180    # auto-stop after this many seconds of continuous silence
silence_check_interval_sec = 3.0   # how often the silence monitor samples the audio
silence_window_sec = 3.0     # length of audio (seconds) analysed on each sample
silence_rms_threshold = 0.015      # normalised RMS (0..1); below this = silence.
                                   # Raise if a noisy room never auto-stops; lower if it
                                   # stops while you're still (quietly) speaking.

# --- Transcript cleanup ---
filter_non_speech = true     # drop whisper's non-speech tokens like "[Silence]",
                             # "[Foreign Language]", "[Birds singing]", "(silence)".
collapse_newlines = true     # join whisper's ~5s per-segment newlines into spaces, so the
                             # text flows instead of stair-casing. (Real paragraph/break
                             # logic comes in a later release.)
drop_hallucinations = true   # drop whisper's silence hallucinations ("Thanks for watching",
                             # "The end", subtitle credits, …) when a segment is only that.
skip_silent_recordings = true  # if no part of the recording exceeds the speech RMS
                             # threshold (silence_rms_threshold), skip transcription entirely
                             # instead of letting whisper hallucinate on silence.

# --- Text insertion --- (see specs/0001-text-insertion.md)
# ASCII is typed via ydotool (universal). Non-ASCII (e.g. Polish ąęóśżźćń) is inserted via
# the clipboard + a paste keystroke, because ydotool 1.x cannot type non-ASCII keys (and
# xdotool, which can, deadlocked the X server). On wlroots Wayland, wtype types Unicode.
insert_backend = "auto"      # "auto" | "clipboard" | "wtype" | "ydotool" | "ibus".
                             # auto: wtype on wlroots Wayland, else clipboard. clipboard works
                             # everywhere (X11 + Wayland). ydotool = ASCII-only fallback.
paste_keys = "auto"          # paste shortcut for non-ASCII: "auto" (terminals get
                             # Ctrl+Shift+V via xprop focus detection, other apps Ctrl+V),
                             # or force "ctrl+v" / "ctrl+shift+v".
preserve_clipboard = true    # restore your clipboard after a paste. Set false to instead
                             # leave the transcript on the clipboard as a re-paste safety net.
key_delay_ms = 0             # inter-key delay when typing; 0 = fastest

# --- Notifications ---
# The animated panel icon already shows idle/listening/transcribing, so the old
# per-dictation "done" popups were just noise (and lit the clock's unread dot).
notify_level = "error"       # "error" = only failures (default) | "off" = silent |
                             # "all" = also routine status (done / empty / busy / cancelled)
